DISCORD_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Optional: set this if FFmpeg is not available on your system PATH.
# Use forward slashes on Windows.
# FFMPEG_EXECUTABLE_PATH=C:/ffmpeg/bin/ffmpeg.exe

# Optional: maximum song duration, in seconds, that will be downloaded into the cache.
# Longer songs can still be streamed.
MAX_SONG_DURATION_SECONDS=1800

# Optional: prevent new song downloads while still reusing files already in song_cache/.
# You can also start the bot with --no-cache or use start_bot_no_cache.bat.
# DISABLE_SONG_CACHE=false

# Optional: override runtime data locations.
# DATABASE_FILE_PATH=database/music_log.db
# LOG_FILE_PATH=logs/music_bot.log
